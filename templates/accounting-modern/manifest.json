{
  "name": "accounting-modern",
  "description": "Dark, bold design for forward-thinking accounting and advisory firms. Deep gradient backgrounds, animated counters, blog integration, and a tech-forward feel.",
  "source": "@bundui",
  "types": ["accounting", "cpa", "tax", "bookkeeping", "financial-advisor"],
  "global": [
    { "name": "navbars-03", "optional": false,
      "fields": {
        "logo_text": { "type": "string", "hint": "Firm name or initials" },
        "nav_links": { "type": "array", "items": { "label": "string", "href": "string" } },
        "cta_label": { "type": "string", "hint": "e.g. 'Book a Call'" },
        "cta_href": { "type": "string" }
      }
    },
    { "name": "footers", "optional": false,
      "fields": {
        "business_name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "social_links": { "type": "array", "items": { "platform": "string", "url": "string" } }
      }
    },
    { "name": "cookie-consent-02", "optional": true,
      "fields": {
        "message": { "type": "string" },
        "accept_label": { "type": "string" },
        "decline_label": { "type": "string" }
      }
    }
  ],
  "pages": [
    {
      "route": "/",
      "title": "Home",
      "blocks": [
        { "name": "banners-02", "optional": true,
          "fields": {
            "message": { "type": "string", "hint": "e.g. 'Tax season is here — book your appointment before slots fill up.'" },
            "cta_label": { "type": "string" }
          }
        },
        { "name": "hero-sections-04", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "Firm name + bold value prop, e.g. 'Modern Accounting for Ambitious Businesses'" },
            "subtitle": { "type": "string", "hint": "e.g. 'Cloud-based CPA firm delivering real-time financial insights, strategic tax planning, and outsourced CFO services.'" },
            "cta_primary_label": { "type": "string", "hint": "e.g. 'Start Your Free Assessment'" },
            "cta_secondary_label": { "type": "string" }
          }
        },
        { "name": "logo-clouds-02", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Trusted by Industry Leaders'" },
            "logos": { "type": "array", "items": { "name": "string", "url": "string" } }
          }
        },
        { "name": "feature-sections", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'How We Help You Grow'" },
            "subtitle": { "type": "string" },
            "features": { "type": "array", "items": { "title": "string", "description": "string" }, "hint": "Services: Tax Strategy, Audit & Assurance, Fractional CFO, Payroll, Business Valuation, M&A Advisory" }
          }
        },
        { "name": "stats-section-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Impact'" },
            "stats": { "type": "array", "items": { "label": "string", "value": "string" }, "hint": "Tax savings delivered, businesses served, years combined experience" }
          }
        },
        { "name": "testimonials-03", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Hear From Our Clients'" },
            "testimonials": { "type": "array", "items": { "quote": "string", "author": "string", "role": "string" } }
          }
        },
        { "name": "integrations", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'We Work With The Tools You Already Use'" },
            "tools": { "type": "array", "items": { "name": "string", "description": "string" }, "hint": "QuickBooks, Xero, NetSuite, Bill.com, Gusto, etc." }
          }
        },
        { "name": "blog-sections-01", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Latest Insights' or 'Tax & Finance Blog'" },
            "posts": { "type": "array", "items": { "title": "string", "excerpt": "string", "date": "string", "category": "string" } }
          }
        },
        { "name": "cta-sections-02", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Let's Build Your Financial Future'" },
            "body": { "type": "string" },
            "button_label": { "type": "string", "hint": "e.g. 'Schedule a Discovery Call'" }
          }
        },
        { "name": "promotional-01", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Free Tax Planning Guide'" },
            "body": { "type": "string" },
            "cta_label": { "type": "string", "hint": "e.g. 'Download Now'" }
          }
        }
      ]
    },
    {
      "route": "/about",
      "title": "About Us",
      "blocks": [
        { "name": "hero-sections-05", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'About [Firm Name]' or 'Our Story'" },
            "subtitle": { "type": "string", "hint": "Firm history, founding vision" }
          }
        },
        { "name": "stats-section-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'By the Numbers'" },
            "stats": { "type": "array", "items": { "label": "string", "value": "string" } }
          }
        },
        { "name": "team-sections-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Team' or 'Meet the Partners'" },
            "members": { "type": "array", "items": { "name": "string", "role": "string", "bio": "string", "image_url": "string" } }
          }
        },
        { "name": "bento-grids", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Values' or 'What Sets Us Apart'" },
            "items": { "type": "array", "items": { "title": "string", "description": "string" } }
          }
        },
        { "name": "blog-sections-02", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Recent Articles'" },
            "posts": { "type": "array", "items": { "title": "string", "excerpt": "string", "date": "string" } }
          }
        },
        { "name": "cta-sections-04", "optional": true,
          "fields": {
            "heading": { "type": "string" },
            "body": { "type": "string" },
            "button_label": { "type": "string" }
          }
        }
      ]
    },
    {
      "route": "/services",
      "title": "Services",
      "blocks": [
        { "name": "hero-sections-03", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Services Tailored to Your Business'" },
            "subtitle": { "type": "string" }
          }
        },
        { "name": "feature-sections", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'End-to-End Financial Services'" },
            "features": { "type": "array", "items": { "title": "string", "description": "string" }, "hint": "Detailed service breakdown per category" }
          }
        },
        { "name": "pricing-sections-02", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Transparent Pricing' or 'Service Tiers'" },
            "plans": { "type": "array", "items": { "name": "string", "price": "string", "description": "string", "features": "array" } }
          }
        },
        { "name": "integrations", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Seamless Integrations'" },
            "tools": { "type": "array", "items": { "name": "string", "description": "string" } }
          }
        },
        { "name": "promotional-02", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'New Client Special'" },
            "body": { "type": "string" },
            "cta_label": { "type": "string" }
          }
        },
        { "name": "cta-sections-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Not Sure What You Need?'" },
            "body": { "type": "string" },
            "button_label": { "type": "string", "hint": "e.g. 'Get a Free Consultation'" }
          }
        }
      ]
    },
    {
      "route": "/contact",
      "title": "Contact",
      "blocks": [
        { "name": "hero-sections-02", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Let's Talk' or 'Get In Touch'" },
            "subtitle": { "type": "string", "hint": "e.g. 'We respond within one business day.'" }
          }
        },
        { "name": "contact-sections", "optional": false,
          "fields": {
            "heading": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "hours": { "type": "string" }
          }
        },
        { "name": "newsletter-sections", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Join Our Mailing List'" },
            "body": { "type": "string" }
          }
        },
        { "name": "banners-03", "optional": true,
          "fields": {
            "message": { "type": "string", "hint": "e.g. 'Extended hours during tax season — walk-ins welcome.'" },
            "cta_label": { "type": "string" }
          }
        },
        { "name": "testimonials-01", "optional": true,
          "fields": {
            "heading": { "type": "string" },
            "testimonials": { "type": "array", "items": { "quote": "string", "author": "string", "role": "string" } }
          }
        }
      ]
    }
  ]
}
