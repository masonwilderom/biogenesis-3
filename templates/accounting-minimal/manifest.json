{
  "name": "accounting-minimal",
  "description": "Clean, white-space-driven design for boutique accounting firms. Extraordinary restraint in decoration, focus on clarity and numbers. Light typography, minimal cards, generous padding.",
  "source": "@tailark",
  "types": ["accounting", "cpa", "tax", "bookkeeping", "financial-advisor"],
  "global": [
    { "name": "footer-2", "optional": false,
      "fields": {
        "business_name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "nav_links": { "type": "array", "items": { "label": "string", "href": "string" } }
      }
    }
  ],
  "pages": [
    {
      "route": "/",
      "title": "Home",
      "blocks": [
        { "name": "hero-section-3", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "Firm name, clean and minimal, e.g. 'Miller Accounting'" },
            "subtitle": { "type": "string", "hint": "Single-line value prop, e.g. 'Precision tax and advisory for growing businesses.'" },
            "cta_label": { "type": "string", "hint": "e.g. 'Work With Us'" },
            "cta_href": { "type": "string" }
          }
        },
        { "name": "logo-cloud-1", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Trusted By'" },
            "logos": { "type": "array", "items": { "name": "string", "url": "string" } }
          }
        },
        { "name": "features-3", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'What We Do'" },
            "subtitle": { "type": "string" },
            "features": { "type": "array", "items": { "title": "string", "description": "string", "icon": "string" }, "hint": "Tax Preparation, Bookkeeping, Payroll, Business Advisory, Audit Support" }
          }
        },
        { "name": "stats-1", "optional": false,
          "fields": {
            "heading": { "type": "string" },
            "stats": { "type": "array", "items": { "label": "string", "value": "string" }, "hint": "Years in practice, clients served, returns filed, tax savings" }
          }
        },
        { "name": "content-2", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Approach' or 'How We Work'" },
            "body": { "type": "string", "hint": "1-2 paragraphs about the firm's philosophy" },
            "image_url": { "type": "string" }
          }
        },
        { "name": "testimonials-1", "optional": true,
          "fields": {
            "heading": { "type": "string" },
            "testimonials": { "type": "array", "items": { "quote": "string", "author": "string", "role": "string" } }
          }
        },
        { "name": "call-to-action-1", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Ready for clarity in your finances?'" },
            "body": { "type": "string" },
            "button_label": { "type": "string", "hint": "e.g. 'Schedule a Call'" },
            "button_href": { "type": "string" }
          }
        },
        { "name": "faqs-1", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Common Questions'" },
            "faqs": { "type": "array", "items": { "question": "string", "answer": "string" } }
          }
        }
      ]
    },
    {
      "route": "/about",
      "title": "About Us",
      "blocks": [
        { "name": "hero-section-1", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'About Miller Accounting'" },
            "subtitle": { "type": "string" }
          }
        },
        { "name": "content-1", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Story'" },
            "body": { "type": "string", "hint": "Firm history, founding story, mission" },
            "image_url": { "type": "string" }
          }
        },
        { "name": "team-1", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Team'" },
            "members": { "type": "array", "items": { "name": "string", "role": "string", "bio": "string", "image_url": "string" } }
          }
        },
        { "name": "stats-2", "optional": true,
          "fields": {
            "heading": { "type": "string" },
            "stats": { "type": "array", "items": { "label": "string", "value": "string" } }
          }
        },
        { "name": "testimonials-2", "optional": true,
          "fields": {
            "heading": { "type": "string" },
            "testimonials": { "type": "array", "items": { "quote": "string", "author": "string", "role": "string" } }
          }
        }
      ]
    },
    {
      "route": "/services",
      "title": "Services",
      "blocks": [
        { "name": "hero-section-5", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Services' or 'How We Can Help'" },
            "subtitle": { "type": "string" }
          }
        },
        { "name": "features-5", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Service Areas'" },
            "subtitle": { "type": "string" },
            "features": { "type": "array", "items": { "title": "string", "description": "string" }, "hint": "Detailed service cards with descriptions" }
          }
        },
        { "name": "pricing-2", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Service Packages'" },
            "plans": { "type": "array", "items": { "name": "string", "price": "string", "description": "string", "features": "array" } }
          }
        },
        { "name": "faqs-2", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Service FAQ'" },
            "faqs": { "type": "array", "items": { "question": "string", "answer": "string" } }
          }
        },
        { "name": "call-to-action-2", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Need something custom?'" },
            "body": { "type": "string" },
            "button_label": { "type": "string" },
            "button_href": { "type": "string" }
          }
        }
      ]
    },
    {
      "route": "/contact",
      "title": "Contact",
      "blocks": [
        { "name": "hero-section-6", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Get In Touch'" },
            "subtitle": { "type": "string", "hint": "e.g. 'We typically respond within 24 hours.'" }
          }
        },
        { "name": "contact-1", "optional": false,
          "fields": {
            "heading": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        { "name": "content-3", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Visit Our Office' or 'Office Hours'" },
            "body": { "type": "string", "hint": "Location details, parking info, hours" },
            "image_url": { "type": "string" }
          }
        },
        { "name": "faqs-3", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Before You Reach Out'" },
            "faqs": { "type": "array", "items": { "question": "string", "answer": "string" } }
          }
        },
        { "name": "call-to-action-3", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Prefer to schedule online?'" },
            "body": { "type": "string" },
            "button_label": { "type": "string" },
            "button_href": { "type": "string" }
          }
        }
      ]
    }
  ]
}
