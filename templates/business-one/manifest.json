{
  "name": "business-one",
  "description": "General-purpose small business landing page. Blocks sourced from bundui.",
  "source": "bundui",
  "types": ["*"],
  "blocks": [
    {
      "name": "hero-sections-01",
      "optional": false,
      "fields": {
        "heading": { "type": "string", "hint": "Main headline text" },
        "subtitle": { "type": "string", "hint": "Subtitle below heading" },
        "cta_primary_label": { "type": "string", "hint": "Primary button text" },
        "cta_secondary_label": { "type": "string", "hint": "Secondary button text" }
      }
    },
    {
      "name": "feature-sections",
      "optional": false,
      "fields": {
        "heading": { "type": "string", "hint": "Section heading, e.g. 'What We Offer'" },
        "subtitle": { "type": "string", "hint": "Brief description below heading" },
        "features": {
          "type": "array",
          "hint": "Feature items",
          "items": { "title": "string", "description": "string" }
        }
      }
    },
    {
      "name": "cta-sections-01",
      "optional": false,
      "fields": {
        "heading": { "type": "string", "hint": "CTA heading" },
        "body": { "type": "string", "hint": "Supporting text" },
        "button_label": { "type": "string", "hint": "Button text" }
      }
    },
    {
      "name": "testimonials-01",
      "optional": true,
      "fields": {
        "heading": { "type": "string", "hint": "Section heading" },
        "testimonials": {
          "type": "array",
          "hint": "Customer testimonials",
          "items": { "quote": "string", "author": "string", "role": "string" }
        }
      }
    },
    {
      "name": "footers",
      "optional": false,
      "fields": {
        "business_name": { "type": "string", "hint": "Business name" },
        "email": { "type": "string", "hint": "Contact email" },
        "phone": { "type": "string", "hint": "Contact phone" },
        "address": { "type": "string", "hint": "Business address" }
      }
    }
  ]
}
