{
  "name": "accounting-premium",
  "description": "Full-featured, visually immersive design for high-end accounting and advisory firms. Dense content, rich testimonial sections, animated features (mist kit), comprehensive service comparisons, and integrations showcase. The 'everything' template.",
  "source": "@tailark",
  "types": ["accounting", "cpa", "tax", "bookkeeping", "financial-advisor"],
  "global": [
    { "name": "footer-4", "optional": false,
      "fields": {
        "business_name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "nav_links": { "type": "array", "items": { "label": "string", "href": "string" } },
        "social_links": { "type": "array", "items": { "platform": "string", "url": "string" } },
        "newsletter_placeholder": { "type": "string" }
      }
    }
  ],
  "pages": [
    {
      "route": "/",
      "title": "Home",
      "blocks": [
        { "name": "hero-section-7", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Redefining Financial Advisory — [Firm Name]' or 'Strategic Accounting for Visionary Leaders'" },
            "subtitle": { "type": "string", "hint": "e.g. 'Full-service CPA and advisory firm serving high-growth companies, family offices, and international enterprises.'" },
            "cta_primary_label": { "type": "string", "hint": "e.g. 'Explore Our Services'" },
            "cta_secondary_label": { "type": "string", "hint": "e.g. 'Meet Our Team'" },
            "announcement_text": { "type": "string", "hint": "Optional banner: e.g. 'Now offering R&D tax credit services — learn more'" }
          }
        },
        { "name": "logo-cloud-2", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Recognized By' or 'Industry Affiliations'" },
            "logos": { "type": "array", "items": { "name": "string", "url": "string" }, "hint": "AICPA, state CPA societies, business awards, client logos" }
          }
        },
        { "name": "features-8", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Comprehensive Financial Services'" },
            "subtitle": { "type": "string" },
            "features": { "type": "array", "items": { "title": "string", "description": "string", "icon": "string" }, "hint": "Tax Planning & Compliance, Audit & Assurance, Fractional CFO, M&A Advisory, Estate & Trust, International Tax, Business Valuation, Risk Management" }
          }
        },
        { "name": "stats-3", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Firm at a Glance'" },
            "stats": { "type": "array", "items": { "label": "string", "value": "string" }, "hint": "Assets under advisement, clients worldwide, team CPAs, years in business, tax savings delivered" }
          }
        },
        { "name": "content-4", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Why [Firm Name]?' or 'The Difference'" },
            "body": { "type": "string", "hint": "What sets the firm apart — proactive advisory, industry specialization, technology-forward approach" },
            "image_url": { "type": "string" }
          }
        },
        { "name": "testimonials-4", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Client Success Stories'" },
            "testimonials": { "type": "array", "items": { "quote": "string", "author": "string", "role": "string", "company": "string" } }
          }
        },
        { "name": "integrations-1", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Technology Partners' or 'We Integrate With'" },
            "tools": { "type": "array", "items": { "name": "string", "description": "string" }, "hint": "QuickBooks, Xero, NetSuite, SAP, Oracle, Bill.com, Expensify, Gusto, ADP" }
          }
        },
        { "name": "call-to-action-3", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Let's Start a Conversation'" },
            "body": { "type": "string" },
            "button_label": { "type": "string", "hint": "e.g. 'Book a Consultation'" },
            "button_href": { "type": "string" }
          }
        },
        { "name": "mist-call-to-action-1", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "Secondary CTA, e.g. 'Download Our Free Guide to Tax Strategy'" },
            "body": { "type": "string" },
            "button_label": { "type": "string" }
          }
        }
      ]
    },
    {
      "route": "/about",
      "title": "About Us",
      "blocks": [
        { "name": "hero-section-8", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Firm' or 'About [Firm Name]'" },
            "subtitle": { "type": "string" }
          }
        },
        { "name": "content-5", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Story' or 'How We Got Here'" },
            "body": { "type": "string", "hint": "Detailed firm history, founding partners, evolution" },
            "image_url": { "type": "string" }
          }
        },
        { "name": "stats-4", "optional": true,
          "fields": {
            "heading": { "type": "string" },
            "stats": { "type": "array", "items": { "label": "string", "value": "string" } }
          }
        },
        { "name": "team-2", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Leadership' or 'Our Partners'" },
            "members": { "type": "array", "items": { "name": "string", "role": "string", "bio": "string", "image_url": "string", "credentials": "string" }, "hint": "Partners, senior managers, key team members with CPA/CFA designations" }
          }
        },
        { "name": "testimonials-5", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'What Leaders Say About Us'" },
            "testimonials": { "type": "array", "items": { "quote": "string", "author": "string", "role": "string", "company": "string" } }
          }
        },
        { "name": "integrations-2", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Professional Affiliations'" },
            "tools": { "type": "array", "items": { "name": "string" }, "hint": "AICPA, PCAOB, state societies, industry groups" }
          }
        },
        { "name": "mist-content-1", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Commitment' or 'Values'" },
            "body": { "type": "string" }
          }
        }
      ]
    },
    {
      "route": "/services",
      "title": "Services",
      "blocks": [
        { "name": "hero-section-9", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Services & Solutions'" },
            "subtitle": { "type": "string" }
          }
        },
        { "name": "features-11", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'What We Offer'" },
            "subtitle": { "type": "string" },
            "features": { "type": "array", "items": { "title": "string", "description": "string", "icon": "string" }, "hint": "Detailed service descriptions for each practice area" }
          }
        },
        { "name": "pricing-4", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Engagement Tiers' or 'Service Packages'" },
            "plans": { "type": "array", "items": { "name": "string", "price": "string", "description": "string", "features": "array" } }
          }
        },
        { "name": "comparator-1", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Compare Service Tiers' or 'Which Plan Is Right For You?'" },
            "columns": { "type": "array", "items": { "name": "string", "features": "array" } }
          }
        },
        { "name": "faqs-3", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Service FAQ'" },
            "faqs": { "type": "array", "items": { "question": "string", "answer": "string" } }
          }
        },
        { "name": "mist-features-1", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Industry Expertise' or 'Specialized Sectors'" },
            "features": { "type": "array", "items": { "title": "string", "description": "string" }, "hint": "Industries served: tech, healthcare, real estate, manufacturing, professional services" }
          }
        },
        { "name": "call-to-action-1", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Need a Custom Engagement?'" },
            "body": { "type": "string" },
            "button_label": { "type": "string", "hint": "e.g. 'Contact Our Team'" },
            "button_href": { "type": "string" }
          }
        }
      ]
    },
    {
      "route": "/contact",
      "title": "Contact",
      "blocks": [
        { "name": "hero-section-2", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Contact Us' or 'Get In Touch'" },
            "subtitle": { "type": "string", "hint": "e.g. 'Our team is ready to help.'" }
          }
        },
        { "name": "contact-2", "optional": false,
          "fields": {
            "heading": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "hours": { "type": "string" }
          }
        },
        { "name": "content-6", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Offices' or 'Visit Us'" },
            "body": { "type": "string", "hint": "Multiple office locations, directions, parking" },
            "image_url": { "type": "string" }
          }
        },
        { "name": "faqs-4", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Before You Contact Us'" },
            "faqs": { "type": "array", "items": { "question": "string", "answer": "string" }, "hint": "Common questions about consultations, pricing, onboarding" }
          }
        },
        { "name": "integrations-3", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'We Come To You' or 'Virtual & In-Person'" },
            "tools": { "type": "array", "items": { "name": "string", "description": "string" }, "hint": "Zoom, Teams, secure client portal, in-person meetings" }
          }
        },
        { "name": "mist-contact-1", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Schedule a Call Directly'" },
            "body": { "type": "string" }
          }
        },
        { "name": "call-to-action-2", "optional": true,
          "fields": {
            "heading": { "type": "string" },
            "body": { "type": "string" },
            "button_label": { "type": "string" },
            "button_href": { "type": "string" }
          }
        }
      ]
    }
  ]
}
