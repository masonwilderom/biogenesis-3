{
  "name": "accounting-classic",
  "description": "Traditional, trustworthy design for CPA firms and established accounting practices. Warm navy tones, serif-inspired typography, client logo showcase, and a focus on credentials and experience.",
  "source": "@bundui",
  "types": ["accounting", "cpa", "tax", "bookkeeping", "financial-advisor"],
  "global": [
    { "name": "navbars-01", "optional": false,
      "fields": {
        "logo_text": { "type": "string", "hint": "Firm name or initials for the navbar brand" },
        "nav_links": {
          "type": "array",
          "items": { "label": "string", "href": "string" },
          "hint": "Nav links: Home -> /, About -> /about, Services -> /services, Contact -> /contact"
        },
        "cta_label": { "type": "string", "hint": "Nav CTA button, e.g. 'Free Consultation'" },
        "cta_href": { "type": "string" }
      }
    },
    { "name": "footers", "optional": false,
      "fields": {
        "business_name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "social_links": {
          "type": "array",
          "items": { "platform": "string", "url": "string" }
        }
      }
    }
  ],
  "pages": [
    {
      "route": "/",
      "title": "Home",
      "blocks": [
        { "name": "hero-sections-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "Firm name + tagline, e.g. 'Smith & Associates — Trusted CPAs Since 1985'" },
            "subtitle": { "type": "string", "hint": "One-line value proposition, e.g. 'Comprehensive accounting, tax, and advisory services for businesses and individuals.'" },
            "cta_primary_label": { "type": "string", "hint": "Primary button, e.g. 'Schedule a Consultation'" },
            "cta_secondary_label": { "type": "string", "hint": "Secondary button, e.g. 'Our Services'" }
          }
        },
        { "name": "logo-clouds-01", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Trusted By' or 'Proud Members Of'" },
            "logos": { "type": "array", "items": { "name": "string", "url": "string" }, "hint": "Client logos or professional association memberships (AICPA, state CPA society, etc.)" }
          }
        },
        { "name": "feature-sections", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Services' or 'What We Do'" },
            "subtitle": { "type": "string", "hint": "Brief intro to services" },
            "features": { "type": "array", "items": { "title": "string", "description": "string", "icon": "string" }, "hint": "3-6 service cards: Tax Preparation, Audit & Assurance, Bookkeeping, Payroll, Business Advisory, Estate Planning" }
          }
        },
        { "name": "stats-section-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'By the Numbers'" },
            "stats": { "type": "array", "items": { "label": "string", "value": "string" }, "hint": "e.g. Years in Business, Clients Served, Returns Filed, Team Members" }
          }
        },
        { "name": "testimonials-01", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'What Our Clients Say'" },
            "testimonials": { "type": "array", "items": { "quote": "string", "author": "string", "role": "string" }, "hint": "Skip if no testimonials found on the source site" }
          }
        },
        { "name": "cta-sections-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Ready to Take Control of Your Finances?'" },
            "body": { "type": "string", "hint": "Encouraging text about scheduling a consultation" },
            "button_label": { "type": "string", "hint": "e.g. 'Get Started Today'" }
          }
        },
        { "name": "newsletter-sections", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Stay Informed' or 'Tax Tips Newsletter'" },
            "body": { "type": "string", "hint": "Brief about the newsletter value" },
            "placeholder": { "type": "string", "hint": "Email input placeholder" }
          }
        },
        { "name": "cookie-consent-01", "optional": true,
          "fields": {
            "message": { "type": "string", "hint": "Cookie consent message" },
            "accept_label": { "type": "string" },
            "decline_label": { "type": "string" }
          }
        }
      ]
    },
    {
      "route": "/about",
      "title": "About Us",
      "blocks": [
        { "name": "hero-sections-02", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'About Smith & Associates'" },
            "subtitle": { "type": "string", "hint": "Brief firm history or mission statement" }
          }
        },
        { "name": "stats-section-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Track Record'" },
            "stats": { "type": "array", "items": { "label": "string", "value": "string" }, "hint": "Key firm metrics" }
          }
        },
        { "name": "team-sections-01", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Meet Our Team' or 'Our Leadership'" },
            "members": { "type": "array", "items": { "name": "string", "role": "string", "bio": "string", "image_url": "string" }, "hint": "Key team members, partners, and CPAs" }
          }
        },
        { "name": "testimonials-02", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Client Success Stories'" },
            "testimonials": { "type": "array", "items": { "quote": "string", "author": "string", "role": "string" } }
          }
        },
        { "name": "cta-sections-03", "optional": true,
          "fields": {
            "heading": { "type": "string" },
            "body": { "type": "string" },
            "button_label": { "type": "string" }
          }
        }
      ]
    },
    {
      "route": "/services",
      "title": "Services",
      "blocks": [
        { "name": "hero-sections-03", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Our Services' or 'What We Offer'" },
            "subtitle": { "type": "string", "hint": "Brief overview of service areas" }
          }
        },
        { "name": "feature-sections", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Comprehensive Financial Services'" },
            "features": { "type": "array", "items": { "title": "string", "description": "string" }, "hint": "Detailed service descriptions" }
          }
        },
        { "name": "pricing-sections-01", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Service Packages' or 'Pricing Plans'" },
            "plans": { "type": "array", "items": { "name": "string", "price": "string", "description": "string", "features": "array" }, "hint": "Skip if no pricing info found" }
          }
        },
        { "name": "bento-grids", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Why Choose Us' or 'Our Process'" },
            "items": { "type": "array", "items": { "title": "string", "description": "string", "icon": "string" } }
          }
        },
        { "name": "faq-sections", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Frequently Asked Questions'" },
            "faqs": { "type": "array", "items": { "question": "string", "answer": "string" } }
          }
        },
        { "name": "cta-sections-02", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Need a Custom Solution?'" },
            "body": { "type": "string" },
            "button_label": { "type": "string", "hint": "e.g. 'Contact Us'" }
          }
        }
      ]
    },
    {
      "route": "/contact",
      "title": "Contact",
      "blocks": [
        { "name": "hero-sections-05", "optional": false,
          "fields": {
            "heading": { "type": "string", "hint": "e.g. 'Get In Touch' or 'Contact Us'" },
            "subtitle": { "type": "string", "hint": "e.g. 'We'd love to hear from you.'" }
          }
        },
        { "name": "contact-sections", "optional": false,
          "fields": {
            "heading": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "hours": { "type": "string", "hint": "Office hours, e.g. 'Mon-Fri 9AM-5PM'" }
          }
        },
        { "name": "newsletter-sections", "optional": true,
          "fields": {
            "heading": { "type": "string", "hint": "Repeat newsletter if not on landing page" },
            "body": { "type": "string" }
          }
        },
        { "name": "banners-01", "optional": true,
          "fields": {
            "message": { "type": "string", "hint": "e.g. 'Now accepting new clients for the upcoming tax season — schedule today.'" },
            "cta_label": { "type": "string" }
          }
        }
      ]
    }
  ]
}
